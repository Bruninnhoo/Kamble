generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum TeacherStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EnglishLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ClassStatus {
  ACTIVE
  INACTIVE
  FULL
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum AssignmentStatus {
  OPEN
  SUBMITTED
  GRADED
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(STUDENT)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student        Student?
  teacher        Teacher?
  refreshTokens  RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Student ──────────────────────────────────────────────────────────────────

model Student {
  id      String        @id @default(cuid())
  userId  String        @unique
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  level   EnglishLevel?

  enrollments         Enrollment[]
  assignmentSubmissions AssignmentSubmission[]
  payments            Payment[]

  @@map("students")
}

// ─── Teacher ──────────────────────────────────────────────────────────────────

model Teacher {
  id     String        @id @default(cuid())
  userId String        @unique
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status TeacherStatus @default(PENDING)
  bio    String?

  classes  Class[]
  sessions Session[]

  @@map("teachers")
}

// ─── Class ───────────────────────────────────────────────────────────────────

model Class {
  id          String      @id @default(cuid())
  name        String
  teacherId   String
  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  level       EnglishLevel
  maxStudents Int         @default(10)
  status      ClassStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  schedule    ClassSchedule[]
  enrollments Enrollment[]
  sessions    Session[]
  assignments Assignment[]
  payments    Payment[]

  @@map("classes")
}

model ClassSchedule {
  id              String @id @default(cuid())
  classId         String
  class           Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  dayOfWeek       Int    // 0 = Sunday
  startTime       String // HH:mm
  durationMinutes Int    @default(60)

  @@map("class_schedules")
}

// ─── Enrollment ───────────────────────────────────────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  enrolledAt DateTime @default(now())
  active    Boolean  @default(true)

  @@unique([studentId, classId])
  @@map("enrollments")
}

// ─── Session (Live Class) ─────────────────────────────────────────────────────

model Session {
  id           String        @id @default(cuid())
  classId      String
  class        Class         @relation(fields: [classId], references: [id])
  teacherId    String
  teacher      Teacher       @relation(fields: [teacherId], references: [id])
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  status       SessionStatus @default(SCHEDULED)
  recordingUrl String?
  createdAt    DateTime      @default(now())

  @@map("sessions")
}

// ─── Assignment ───────────────────────────────────────────────────────────────

model Assignment {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  title       String
  description String
  dueDate     DateTime
  createdAt   DateTime @default(now())

  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id])
  fileUrl      String?
  content      String?
  grade        Float?
  feedback     String?
  submittedAt  DateTime         @default(now())
  status       AssignmentStatus @default(OPEN)

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// ─── Payment (Mock) ───────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id])
  classId   String
  class     Class         @relation(fields: [classId], references: [id])
  amount    Int           // em centavos
  currency  String        @default("BRL")
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  paidAt    DateTime?

  @@map("payments")
}
